{
  "name": "macwlt",
  "version": "0.1.0",
  "private": true,
  "description": "Self-custodial wallet infrastructure for macOS",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "dev": "pnpm --filter @macwlt/cli dev",
    "dev:docs": "pnpm --filter @macwlt/docs dev",
    "dev:landing": "pnpm --filter @macwlt/landing dev",
    "build:docs": "pnpm --filter @macwlt/docs build",
    "build:landing": "pnpm --filter @macwlt/landing build",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:e2e": "pnpm run build && pnpm --filter @macwlt/cli test:e2e",
    "typecheck": "pnpm -r typecheck"
  }
}
