{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["bun"]
  },
  "include": ["src/**/*.ts", "e2e/**/*.ts", "tsup.config.ts"]
}
