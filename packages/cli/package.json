{
  "name": "@macwlt/cli",
  "version": "0.0.4-alpha",
  "description": "TypeScript CLI for the macwlt native core",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/paoloanzn/macwlt.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "bin": {
    "macwlt": "./dist/main.js",
    "_macwlt-signing-service": "./native/com.macwlt.SigningService.xpc/Contents/MacOS/com.macwlt.SigningService"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "native",
    "config.default.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/main.ts",
    "stage:native": "node scripts/stage-native.mjs",
    "prepack": "pnpm run build && pnpm run stage:native",
    "prepublishOnly": "pnpm run typecheck && pnpm test",
    "start": "bun run dist/main.js",
    "test": "bun test",
    "test:e2e": "MACWLT_E2E=1 bun test e2e",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.55.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
