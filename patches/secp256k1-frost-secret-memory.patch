+    secp256k1_memclear(msg_prime, sizeof(msg_prime));
+    secp256k1_memclear(b0, sizeof(b0));
+    secp256k1_memclear(b1, sizeof(b1));
+    secp256k1_memclear(b2, sizeof(b2));
+    secp256k1_memclear(uniform_bytes, sizeof(uniform_bytes));
+    secp256k1_memclear(index2os, sizeof(index2os));
+    secp256k1_memclear(reduced, sizeof(reduced));
+    secp256k1_memclear(&sha, sizeof(sha));
+    secp256k1_memclear(&x, sizeof(x));
+    secp256k1_memclear(&r, sizeof(r));
