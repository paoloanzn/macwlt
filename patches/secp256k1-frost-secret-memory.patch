+    secp256k1_sha256_initialize(&sha);
+    secp256k1_sha256_write(&sha, b0, sizeof(b0));
+    I2OSP(index2os, 1, sizeof(index2os));
+    secp256k1_sha256_write(&sha, index2os, sizeof(index2os));
+    secp256k1_sha256_write(&sha, dst_prime, sizeof(dst_prime));
+    secp256k1_sha256_finalize(&sha, b1);
+
+    strxor(b2, b0, b1, sizeof(b2));
+    secp256k1_sha256_initialize(&sha);
+    secp256k1_sha256_write(&sha, b2, sizeof(b2));
+    I2OSP(index2os, 2, sizeof(index2os));
+    secp256k1_sha256_write(&sha, index2os, sizeof(index2os));
+    secp256k1_sha256_write(&sha, dst_prime, sizeof(dst_prime));
+    secp256k1_sha256_finalize(&sha, b2);
