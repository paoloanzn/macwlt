+    compute_msg_prime(msg_prime, message, sizeof(message),
+                      dst_prime, FROST_DST_H3_LEN, sizeof(uniform_bytes));
+
+    secp256k1_sha256_initialize(&sha);
+    secp256k1_sha256_write(&sha, msg_prime, sizeof(msg_prime));
+    secp256k1_sha256_finalize(&sha, b0);
