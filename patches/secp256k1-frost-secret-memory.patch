+    unsigned char b0[SHA256_SIZE];
+    unsigned char b1[SHA256_SIZE];
+    unsigned char b2[SHA256_SIZE];
+    unsigned char uniform_bytes[48];
+    unsigned char index2os[1];
+    unsigned char reduced[32];
